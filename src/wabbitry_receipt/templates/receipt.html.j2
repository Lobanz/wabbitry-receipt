<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>Wascally Wabbitry — Sale Receipt</title>
        <link rel="stylesheet" href="receipt.css">
    </head>
    <body>
        <header class="business-header">
            <img src="logo.png"
                 alt="Wascally Wabbitry"
                 class="logo"
                 width="80"
                 height="80">
            <div class="business-info">
                <h1>Wascally Wabbitry</h1>
                <p>Hazel Green, AL</p>
                <p>Mike: (256) 701-4664 &middot; wabbitry@protonmail.com</p>
            </div>
        </header>
        <section class="sale-info">
            <div class="sale-row">
                <span><strong>Customer:</strong> {{ sale.customer_name }}</span>
                <span><strong>Date:</strong> {{ sale.sale_date.strftime("%B %d, %Y") }}</span>
            </div>
            <div class="sale-row">
                <span><strong>Contact:</strong> {{ sale.customer_contact }}</span>
                <span></span>
            </div>
        </section>
        {% for item in sale.line_items %}
            <section class="line-item">
                <div class="line-item-header">
                    <span class="line-item-type">
                        {{- item.type.value | title -}}
                        {%- if item.desc and item.desc not in ["MIXED", "PURE"] %}
                            <span class="line-item-desc">{{ item.desc }}</span>
                        {%- else %}
                            {%- set strain_info = namespace(first_breed="", label="") %}
                            {%- for rabbit in item.rabbits %}
                                {%- if loop.first %}
                                    {%- set strain_info.first_breed = rabbit.breed %}
                                {%- elif rabbit.breed != strain_info.first_breed %}
                                    {%- set strain_info.label = strain_info.first_breed ~ " x " ~ rabbit.breed %}
                                {%- endif %}
                            {%- endfor %}
                            {%- if not strain_info.label %}
                                {%- set strain_info.label = strain_info.first_breed %}
                            {%- endif %}
                            <span class="line-item-desc">{{ strain_info.label }}</span>
                        {%- endif %}
                    </span>
                    <span class="line-item-price">${{ "%.2f" | format(item.price) }}</span>
                </div>
                <table class="rabbits-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Gender</th>
                            <th>Breed</th>
                            <th>DOB</th>
                            <th>Sire</th>
                            <th>Dam</th>
                            <th>Marking</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for rabbit in item.rabbits %}
                            <tr class="rabbit-row">
                                <td>{{ loop.index }}</td>
                                <td>{{ "Buck" if rabbit.gender == "M" else "Doe" }}</td>
                                <td class="breed">{{ rabbit.breed }}</td>
                                <td>{{ rabbit.dob.strftime("%Y-%m-%d") }}</td>
                                <td class="parentage">{{ rabbit.sire.name }} ({{ rabbit.sire.breed }})</td>
                                <td class="parentage">{{ rabbit.dam.name }} ({{ rabbit.dam.breed }})</td>
                                <td class="marking-area"></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>
        {% endfor %}
        <section class="total-section">
            <div class="total-row">
                <span class="total-label">Total:</span>
                <span class="total-amount">${{ "%.2f" | format(sale.total) }}</span>
            </div>
        </section>
        <section class="hand-notes">
            <h2>Notes</h2>
            <div class="hand-notes-line">{% if sale.notes %}<span class="hand-notes-pre">{{ sale.notes }}</span>{% endif %}</div>
            <div class="hand-notes-line"></div>
            <div class="hand-notes-line"></div>
        </section>
    </body>
</html>
